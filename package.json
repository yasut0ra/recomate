{
  "name": "recomate",
  "version": "1.0.0",
  "description": "会話トピック推薦と能動会話可能なAI",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "concurrently -k -n api,ui \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:web": "concurrently -k -n api,ui \"npm run dev:api\" \"npm run dev:ui:web\"",
    "dev:api": "node scripts/run-api.cjs --reload",
    "dev:ui": "npm --prefix ui run dev:desktop",
    "dev:ui:web": "npm --prefix ui run dev:web",
    "start": "node scripts/run-api.cjs --host 0.0.0.0",
    "build": "npm --prefix ui run build",
    "lint": "npm --prefix ui run lint",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasut0ra/recomate.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/yasut0ra/recomate/issues"
  },
  "homepage": "https://github.com/yasut0ra/recomate#readme",
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
